SIMULATION_MODE=true
LOG_LEVEL=info
POLL_INTERVAL_MS=3000

COINBASE_API_KEY=
COINBASE_API_SECRET=
PRODUCT_ID=BTC-USD

GRID_LOW=58000
GRID_HIGH=62000
GRID_LEVELS=10
ORDER_SIZE=0.001

# Close grid if price breaks range by this percent
BREAKOUT_PCT=2

# Optional Redis (grid state persistence)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_ENABLED=true
# REDIS_KEY_PREFIX=cb-grid:
# REDIS_CACHE_TTL_SEC=86400
